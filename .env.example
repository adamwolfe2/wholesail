# ============================================================
# Wholesail — Required Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Database (Neon)
# Get from: Neon Dashboard → your project → Connection Details
# Use the pooled URL for DATABASE_URL
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------
# Auth (Clerk)
# Get from: Clerk Dashboard → your app → API Keys
# CLERK_WEBHOOK_SECRET: create a webhook endpoint in Clerk
# pointing to https://yourdomain.com/api/webhooks/clerk
# Events: user.created, user.updated, user.deleted
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# Payments (Stripe)
# Get from: Stripe Dashboard → Developers → API Keys
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Webhooks → endpoint
# Events: checkout.session.completed, invoice.paid,
#   payment_intent.succeeded, charge.refunded
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# Email (Resend)
# Get from: Resend Dashboard → API Keys
# IMPORTANT: verify your sending domain in Resend before
# emails will deliver (add SPF + DKIM DNS records)
# ------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Your Company <noreply@yourdomain.com>"

# ------------------------------------------------------------
# AI (Anthropic + optional Google Gemini)
# Anthropic: console.anthropic.com → API Keys
# Gemini: console.cloud.google.com → API Keys (for suggest-reply)
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."
GEMINI_API_KEY=""

# ------------------------------------------------------------
# Web Scraping (Firecrawl)
# Get from: firecrawl.dev → Dashboard → API Keys
# ------------------------------------------------------------
FIRECRAWL_API_KEY="fc-..."

# ------------------------------------------------------------
# Rate Limiting (Upstash KV)
# Get from: Vercel Dashboard → Storage → KV, or upstash.com
# Without these, rate limiting is silently disabled (security gap
# on public endpoints like /api/onboarding and /api/checkout)
# ------------------------------------------------------------
KV_REST_API_URL="https://your-kv.upstash.io"
KV_REST_API_TOKEN="your-upstash-token"

# ------------------------------------------------------------
# Error Tracking (Sentry)
# Get from: Sentry Dashboard → your project → Settings
# ------------------------------------------------------------
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"

# ------------------------------------------------------------
# Cron Job Auth
# Generate a random secret: openssl rand -hex 32
# Used to authenticate requests to /api/cron/* endpoints
# ------------------------------------------------------------
CRON_SECRET="your-random-hex-secret"

# ------------------------------------------------------------
# App & Branding
# Set to your production domain (no trailing slash)
# BRAND_NAME: shown in emails, portal nav, and public pages
# BRAND_LOCATION: shown in email footer (e.g. "Los Angeles, CA")
# NEXT_PUBLIC_BRAND_NAME: client-side brand name (portal nav, status page)
# NEXT_PUBLIC_CONTACT_EMAIL: shown on public status page as contact
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
ADMIN_EMAIL="ops@yourdomain.com"
OPS_NAME="Your Team"
BRAND_NAME="Your Brand"
BRAND_LOCATION="Your City, ST"
NEXT_PUBLIC_BRAND_NAME="Your Brand"
NEXT_PUBLIC_CONTACT_EMAIL="orders@yourdomain.com"

# Delivery & Tax (portal-wide defaults)
FREE_DELIVERY_THRESHOLD=500
STANDARD_DELIVERY_FEE=25
DEFAULT_TAX_RATE=0.0875

# Email template branding (header background, CTA buttons)
BRAND_PRIMARY_COLOR="#0A0A0A"

# Cal.com namespace for embed widget
NEXT_PUBLIC_CAL_NAMESPACE="your-cal-namespace"

# Instagram (social feed component)
# NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/yourhandle/"
# NEXT_PUBLIC_INSTAGRAM_HANDLE="@yourhandle"

# Weekly report recipients (comma-separated emails)
REPORT_RECIPIENTS="admin@yourdomain.com,ops@yourdomain.com"

# Vercel Blob (for file attachments)
# Get from: Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=""

# ------------------------------------------------------------
# Bootstrap (one-time admin setup)
# Generate a random secret: openssl rand -hex 16
# Used once to bootstrap the first admin user at /api/admin/bootstrap
# Remove or rotate after first use.
# ------------------------------------------------------------
BOOTSTRAP_SECRET="your-random-hex-secret"

# ------------------------------------------------------------
# Optional: SMS Ordering (Bloo.io)
# Only needed if SMS ordering is a launch feature
# ------------------------------------------------------------
# BLOOIO_API_KEY=""
# BLOOIO_FROM_NUMBER=""
# BLOOIO_WEBHOOK_SECRET=""

# ============================================================
# BUILD PIPELINE — Required for automated portal provisioning
# These power the "Start Build" button in /admin/intakes/[id]
# ============================================================

# ------------------------------------------------------------
# GitHub (repo creation from template)
# Get PAT from: GitHub → Settings → Developer settings → PATs
# Needs scopes: repo, read:org
# ------------------------------------------------------------
GITHUB_PAT="ghp_..."
GITHUB_OWNER="your-github-org"
GITHUB_TEMPLATE_REPO="wholesail"

# ------------------------------------------------------------
# Vercel API (project creation, storage, deployments)
# Get from: Vercel Dashboard → Settings → Tokens
# WS_VERCEL_TOKEN is the master token for provisioning
# VERCEL_TEAM_ID: optional — if using a team account
# ------------------------------------------------------------
WS_VERCEL_TOKEN="your-vercel-api-token"
# VERCEL_TEAM_ID="team_..."

# ------------------------------------------------------------
# Clerk Platform API (automated app creation)
# Get from: Clerk Dashboard → Platform API (requires beta access)
# Request access: https://clerkdev.notion.site/2df2b9ab44fe803f9031e9f3185c5e19
# Without this, Clerk app creation falls back to manual instructions
# ------------------------------------------------------------
# CLERK_PLATFORM_TOKEN=""

# ------------------------------------------------------------
# Research (Tavily)
# Get from: tavily.com → Dashboard → API Keys
# Used for industry research during build pipeline
# ------------------------------------------------------------
TAVILY_API_KEY=""

# ------------------------------------------------------------
# Cal.com (intake booking sync)
# NEXT_PUBLIC_CAL_LINK: your booking page slug (shown in emails)
# CAL_WEBHOOK_SECRET: webhook auth for booking notifications
# ------------------------------------------------------------
NEXT_PUBLIC_CAL_LINK="adamwolfe/wholesail"
# CAL_WEBHOOK_SECRET=""

# ------------------------------------------------------------
# Slack Notifications (intake alerts)
# Create Incoming Webhook at api.slack.com
# ------------------------------------------------------------
# SLACK_WEBHOOK_URL=""
