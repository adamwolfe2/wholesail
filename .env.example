# ── Database (Neon Serverless PostgreSQL) ──
# Required for intake form submissions, admin dashboard, client status
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Authentication (Clerk) ──
# Required for admin dashboard access
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Email (Resend) ──
# Required for intake confirmation and status update emails
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Wholesail <adam@wholesailhub.com>

# ── Firecrawl (website scraping / brand extraction) ──
FIRECRAWL_API_KEY=fc-...

# ── App URL (used in email templates) ──
NEXT_PUBLIC_APP_URL=https://wholesailhub.com
